FLASK_DEBUG=true
FLASK_APP=app.py
SQLALCHEMY_TRACK_MODIFICATIONS=False
SQLALCHEMY_DATABASE_URI=sqlite:///db.sqlite3
# Required in production (Railway): set a long random string
SECRET_KEY=your_secret_key_here
# Optional: token for POST /api/spot/<id>/status (Arduino / ESP). Default matches demo if unset.
OCCUPANCY_API_TOKEN=demo-nicmar-2026
