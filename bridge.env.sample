# Copy to bridge.env (do not commit bridge.env — it may contain secrets)
# Your deployed app URL (Railway):
BRIDGE_BASE_URL=https://your-service.up.railway.app
# Spot ID from admin dashboard grid (must match the physical slot)
BRIDGE_SPOT_ID=1
# Must match Railway variable OCCUPANCY_API_TOKEN (default demo: demo-nicmar-2026)
BRIDGE_API_TOKEN=demo-nicmar-2026
# Windows: COM3   macOS: /dev/cu.usbserial-XXXX   Linux: /dev/ttyUSB0
BRIDGE_SERIAL_PORT=COM3
BRIDGE_BAUD=9600
